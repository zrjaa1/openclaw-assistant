.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

/* Message List */
.message-list {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}

.message {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.message.user {
  flex-direction: row-reverse;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.bubble {
  max-width: 70%;
  padding: 20rpx 28rpx;
  border-radius: 20rpx;
  margin: 0 16rpx;
  line-height: 1.6;
  word-break: break-all;
}

.message.assistant .bubble {
  background-color: #fff;
  color: #333;
  border-top-left-radius: 4rpx;
}

.message.user .bubble {
  background-color: #1a73e8;
  color: #fff;
  border-top-right-radius: 4rpx;
}

.bubble.typing {
  color: #666;
}

/* Copy Button */
.copy-btn {
  margin-top: 12rpx;
  padding: 8rpx 20rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  display: inline-block;
  font-size: 24rpx;
  color: #1a73e8;
}

.copy-btn:active {
  background-color: #e0e0e0;
}

/* Quota Bar */
.quota-bar {
  padding: 8rpx 20rpx;
  background-color: #fff3cd;
  text-align: center;
  font-size: 24rpx;
  color: #856404;
}

/* Input Area */
.input-area {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  border-top: 1rpx solid #e0e0e0;
}

.input-box {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background-color: #f5f5f5;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.send-btn {
  margin-left: 16rpx;
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  background-color: #1a73e8;
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
  border: none;
}

.send-btn[disabled] {
  background-color: #b0b0b0;
  color: #fff;
}
