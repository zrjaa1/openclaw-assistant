<view class="container">
  <!-- Message List -->
  <scroll-view
    class="message-list"
    scroll-y="true"
    scroll-into-view="{{scrollToId}}"
    enhanced="true"
    show-scrollbar="false"
  >
    <!-- Welcome message -->
    <view class="message assistant" wx:if="{{messages.length === 0}}">
      <view class="avatar">🦞</view>
      <view class="bubble">
        <text>你好！我是小龙虾（OpenClaw）的安装助手 🦞\n\n小龙虾是一个让 AI 住进你微信、飞书、钉钉的开源工具——不用打开新网页，直接在聊天里用 AI。\n\n它能帮你：\n• 在微信里随时问问题，就像跟朋友聊天\n• 每天自动发天气、新闻摘要、工作提醒\n• 发图片让 AI 帮你翻译、分析、总结\n• 你的数据在自己电脑上，不经过第三方\n\n告诉我你的操作系统（Windows、Mac 还是 Linux），我们开始安装吧！</text>
      </view>
    </view>

    <view
      wx:for="{{messages}}"
      wx:key="id"
      class="message {{item.role}}"
      id="msg-{{item.id}}"
    >
      <view class="avatar" wx:if="{{item.role === 'assistant'}}">🦞</view>
      <view class="bubble">
        <rich-text nodes="{{item.rendered || item.content}}"></rich-text>
        <!-- Copy button for code blocks -->
        <view
          class="copy-btn"
          wx:if="{{item.role === 'assistant' && item.hasCode}}"
          bindtap="onCopyCode"
          data-content="{{item.codeContent}}"
        >
          <text>复制命令</text>
        </view>
      </view>
      <view class="avatar" wx:if="{{item.role === 'user'}}">👤</view>
    </view>

    <!-- Typing indicator -->
    <view class="message assistant" wx:if="{{isTyping}}">
      <view class="avatar">🦞</view>
      <view class="bubble typing">
        <text>{{currentResponse || '思考中...'}}</text>
      </view>
    </view>

    <view id="bottom-anchor" style="height: 20rpx;"></view>
  </scroll-view>

  <!-- Quota warning -->
  <view class="quota-bar" wx:if="{{remainingQuota <= 5 && remainingQuota >= 0}}">
    <text>剩余对话次数: {{remainingQuota}}</text>
  </view>

  <!-- Input Area -->
  <view class="input-area">
    <input
      class="input-box"
      value="{{inputText}}"
      placeholder="输入你的问题..."
      confirm-type="send"
      bindinput="onInput"
      bindconfirm="onSend"
      disabled="{{isTyping}}"
    />
    <button class="send-btn" bindtap="onSend" disabled="{{isTyping || !inputText}}">
      发送
    </button>
  </view>
</view>
